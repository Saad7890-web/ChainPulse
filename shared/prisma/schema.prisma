generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
url      = env("DATABASE_URL")
}

enum ShipmentStatus {
  CREATED
  IN_TRANSIT
  DELIVERED
  DELAYED
  CANCELLED
}

enum AlertType {
  DELAY
  ROUTE_DEVIATION
  NO_UPDATE
  SYSTEM
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

model Warehouse {
  id        String     @id @default(uuid())
  name      String
  location  String
  shipments Shipment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  name     String?
  password String
  role     UserRole @default(VIEWER)

  shipmentsCreated Shipment[] @relation("ShipmentCreatedBy")
  alertsCreated    Alert[]     @relation("AlertCreatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shipment {
  id               String         @id @default(uuid())
  trackingNumber   String         @unique
  origin           String
  destination      String
  status           ShipmentStatus @default(CREATED)

  warehouseId      String?
  warehouse        Warehouse?     @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  createdByUserId  String?
  createdByUser    User?          @relation("ShipmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  locationUpdates  LocationUpdate[]
  alerts          Alert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([warehouseId])
}

model LocationUpdate {
  id          String   @id @default(uuid())
  shipmentId  String
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  latitude    Float
  longitude   Float
  recordedAt  DateTime @default(now())

  createdAt DateTime @default(now())

  @@index([shipmentId, recordedAt])
}

model Alert {
  id              String    @id @default(uuid())
  shipmentId      String
  shipment        Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  type            AlertType
  message         String
  status          String    @default("open")

  createdByUserId  String?
  createdByUser    User?     @relation("AlertCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([shipmentId, createdAt])
}